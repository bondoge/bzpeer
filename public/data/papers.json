      "year": 2024,
      "doi": "10.1038/s41593-024-01234-5",
      "color": "#5B8CFF",
      "venue": "Nature Neuroscience",
      "abstract": "We characterize low-dimensional neural manifolds underlying motor cortex population activity during complex voluntary movements, revealing stable geometric structure across subjects.",
      "referencedPaperIds": []
    },
    {
      "id": "paper_002",
      "title": "Transformer Architectures for Neural Population Decoding",
      "year": 2024,
      "doi": "10.1016/j.neuron.2024.05.021",
      "color": "#F97316",
      "venue": "Neuron",
      "abstract": "We introduce NeuroFormer, a transformer-based architecture for decoding motor intentions from large-scale neural recordings with state-of-the-art generalization across sessions.",
      "referencedPaperIds": ["paper_001"]
    },
