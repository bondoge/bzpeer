      "id": "paper_003",
      "title": "Closed-Loop Cortical Stimulation for Motor Recovery after Stroke",
      "year": 2023,
      "doi": "10.1126/science.adg4128",
      "color": "#EF4444",
      "venue": "Science",
      "abstract": "A closed-loop brain-computer interface delivering contingent cortical stimulation during voluntary movement attempts accelerates motor recovery in a randomized controlled trial.",
      "referencedPaperIds": ["paper_001"]
    },
