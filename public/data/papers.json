      "color": "#22C55E",
      "venue": "Nature",
      "abstract": "Theta-phase-specific synaptic tagging in hippocampal CA1 circuits determines which experiences are consolidated into long-term memory during subsequent sleep.",
      "referencedPaperIds": []
    },
